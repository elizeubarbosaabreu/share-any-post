{
  "manifest_version": 3,
  "name": "Share Any Post",
  "version": "1.0",
  "description": "Compartilhe qualquer postagem da internet como story 9:16 com QR code",
  "permissions": ["activeTab", "scripting", "clipboardWrite"],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Share Any Post"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}